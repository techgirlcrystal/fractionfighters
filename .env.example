# ===== CLERK (Authentication) =====
# Get these from https://dashboard.clerk.com → API Keys → Quick Copy
# The publishable key starts with "pk_" — this is safe to expose in the browser
CLERK_PUBLISHABLE_KEY=pk_test_your_publishable_key_here

# The secret key starts with "sk_" — NEVER put this in the frontend code!
# It's only used by your backend (when we add the Neon DB later)
CLERK_SECRET_KEY=sk_test_your_secret_key_here

# ===== NEON TECH (Postgres Database) =====
# Get this from https://console.neon.tech
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/dbname?sslmode=require

# ===== APP =====
# The public URL of your deployed game (Coolify URL)
APP_URL=https://your-coolify-url.example.com
