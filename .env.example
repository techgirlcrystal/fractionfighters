# ===== CLERK (Authentication) =====
# Get these from https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key_here
CLERK_SECRET_KEY=your_clerk_secret_key_here

# ===== NEON TECH (Postgres Database) =====
# Get this from https://console.neon.tech
DATABASE_URL=postgres://user:password@ep-xxx.us-east-2.aws.neon.tech/dbname?sslmode=require

# ===== APP =====
# The public URL of your deployed game (Coolify URL)
APP_URL=https://your-coolify-url.example.com
